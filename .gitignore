# ---- Secrets — never commit these ------------------------------------------
*.env
*.pem
*.key
*_rsa
*_dsa
*_ecdsa
*_ed25519
*.p12
*.pfx

# Machine-specific git config (credential helper, signing key, work email)
git/.gitconfig.local

# ---- OS artifacts -----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor -----------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---- Local Agent Rules (Polyfilled from AGENTS.md) --------------------------
.cursorrules
.windsurfrules
.github/copilot-instructions.md
/CLAUDE.md

# ---- Claude Code — machine-local (never commit) ----------------------------
claude/settings.local.json

# ---- Machine-local state (never commit) -------------------------------------
